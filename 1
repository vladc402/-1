#include <iostream>
#include <cstdlib>

int main() {
    const int SIZE = 10;
    int arr[SIZE];

    for (int i = 0; i < SIZE; i++) {
        arr[i] = rand() % 100 + 1;
    }

    int evenCount = 0, oddCount = 0;

    std::cout << "Array: ";
    for (int i = 0; i < SIZE; i++) {
        std::cout << arr[i] << " ";
        if (arr[i] % 2 == 0)
            evenCount++;
        else
            oddCount++;
    }

    std::cout << "\nEven: " << evenCount << "\nOdd: " << oddCount << std::endl;

    return 0;
}
